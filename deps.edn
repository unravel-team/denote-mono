{:aliases
 {:dev {:extra-deps
        {;; Components
         denote-mono/config {:local/root "components/config"},
         denote-mono/editor {:local/root "components/editor"},
         denote-mono/file-type {:local/root "components/file_type"},
         denote-mono/filename {:local/root "components/filename"},
         denote-mono/filesystem {:local/root "components/filesystem"},
         denote-mono/front-matter {:local/root "components/front_matter"},
         denote-mono/llm {:local/root "components/llm"},
         denote-mono/llm-wiki {:local/root "components/llm_wiki"},
         denote-mono/note {:local/root "components/note"},
         denote-mono/process {:local/root "components/process"},
         denote-mono/rename {:local/root "components/rename"},
         denote-mono/search {:local/root "components/search"},
         denote-mono/sequence {:local/root "components/sequence"},
         denote-mono/silo {:local/root "components/silo"},
         denote-mono/slug {:local/root "components/slug"},
         ;; Bases
         denote-mono/cli {:local/root "bases/cli"}},
        :extra-paths ["development/src"]},
  :test
  {:extra-deps {io.github.cognitect-labs/test-runner {:git/sha "dfb30dd",
                                                      :git/tag "v0.5.1"},
                org.clojure/test.check {:mvn/version "1.1.3"}},
   :extra-paths
   ["components/config/test" "components/editor/test"
    "components/file_type/test" "components/filename/test"
    "components/filesystem/test" "components/front_matter/test"
    "components/llm/test" "components/llm_wiki/test" "components/note/test"
    "components/process/test" "components/rename/test" "components/search/test"
    "components/sequence/test" "components/silo/test" "components/slug/test"
    "bases/cli/test" "projects/denote-cli/test"],
   :main-opts ["-m" "cognitect.test-runner" "-d" "components/config/test" "-d"
               "components/editor/test" "-d" "components/file_type/test" "-d"
               "components/filename/test" "-d" "components/filesystem/test" "-d"
               "components/front_matter/test" "-d" "components/llm/test" "-d"
               "components/llm_wiki/test" "-d" "components/note/test" "-d"
               "components/process/test" "-d" "components/rename/test" "-d"
               "components/search/test" "-d" "components/sequence/test" "-d"
               "components/silo/test" "-d" "components/slug/test" "-d"
               "bases/cli/test" "-d" "projects/denote-cli/test"]},
  ;; Example command: clojure -M:poly info
  :poly {:extra-deps {polyfy/polylith
                      {:deps/root "projects/poly",
                       :git/sha "c804c2c962e5e81c307dcd878f88f8b10ee43403",
                       :git/url "https://github.com/polyfy/polylith"}},
         :main-opts ["-m" "polylith.clj.core.poly-cli.core"]},
  ;; Build with: clojure -T:build uberjar :project denote-cli
  :build {:deps {io.github.clojure/tools.build {:mvn/version "0.10.14"},
                 io.github.seancorfield/build-clj {:git/sha "9c9f078",
                                                   :git/tag "v0.9.2"}},
          :ns-default build},
  :logs-dev
  {:jvm-opts
   ["-Dclojure.tools.logging.factory=clojure.tools.logging.impl/log4j2-factory"
    "-Dorg.eclipse.jetty.util.log.class=org.eclipse.jetty.util.log.Slf4jLog"
    "-Dlog4j2.contextSelector=org.apache.logging.log4j.core.async.AsyncLoggerContextSelector"
    "-Dlog4j2.configurationFile=logger/log4j2.xml"
    ;; Change logging.level to one of TRACE, DEBUG, INFO, WARN, ERROR
    ;; depending on requirement during development
    "-Dlogging.level=DEBUG"]},
  :cider ;; Tooling dependencies
  {:classpath-overrides
   ;; we need to disable the official compiler and use ClojureStorm
   {org.clojure/clojure nil},
   :extra-deps {cider/cider-nrepl {:mvn/version "0.59.0"},
                com.github.flow-storm/clojure {:mvn/version "1.12.5-1"},
                com.github.flow-storm/flow-storm-dbg {:mvn/version "4.6.0"},
                mx.cider/tools.deps.enrich-classpath {:mvn/version "1.19.3"},
                nrepl/nrepl {:mvn/version "1.7.0"},
                refactor-nrepl/refactor-nrepl {:mvn/version "3.13.0"}},
   :main-opts
   ["-m" "nrepl.cmdline" "--middleware"
    "[flow-storm.nrepl.middleware/wrap-flow-storm,cider.nrepl/cider-middleware,refactor-nrepl.middleware/wrap-refactor]"],
   :jvm-opts ["-Dclojure.storm.instrumentEnable=true"
              "-Dclojure.storm.instrumentOnlyPrefixes=denote-mono."]},
  :clofidence ;; Test Coverage, run with `clj -X:dev:test:clofidence`
  {:classpath-overrides {org.clojure/clojure nil},
   :exec-args {:report-name "Denote-Monorepo Coverage Report",
               :test-fn cognitect.test-runner.api/test,
               :test-fn-args [{}]},
   :exec-fn clofidence.main/run,
   :extra-deps {com.github.flow-storm/clofidence {:mvn/version "0.5.0"},
                com.github.flow-storm/clojure {:mvn/version "1.12.5-1"}},
   :jvm-opts ["-Dclojure.storm.instrumentOnlyPrefixes=denote-mono."
              "-Dclojure.storm.instrumentSkipRegex=.*test.*"]}},
 :deps {org.clojure/clojure {:mvn/version "1.12.5"}},
 :license {:name "GNU General Public License v3.0",
           :url "https://www.gnu.org/licenses/gpl-3.0.txt"}}
